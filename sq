# --- dispatch ---------------------------------------------------------------
cmd="${1:-help}"
case "$cmd" in
  start)  do_reset ;;
  reset)  do_reset ;;
  brief|mission) do_brief ;;
  hint)   do_hint ;;
  status) do_status ;;
  map)    do_map ;;
  submit) shift; do_submit "${1:-}" ;;
  help|-h|--help) do_help ;;
  *)
    if is_ja; then
      say "${R}дёҚжҳҺгҒӘгӮігғһгғігғү:${N} $cmd"; say "${C}./sq help${N} гӮ’е®ҹиЎҢгҒ—гҒҰгҒҸгҒ гҒ•гҒ„"
    else
      say "${R}Unknown command:${N} $cmd"; say "Run ${C}./sq help${N}"
    fi
    exit 1 ;;
esac
