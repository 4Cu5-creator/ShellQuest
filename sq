#
#  A terminal CTF that teaches basic shell commands.  Run:  ./sq help
#  еҹәжң¬зҡ„гҒӘгӮ·гӮ§гғ«гӮігғһгғігғүгӮ’еӯҰгҒ№гӮӢгӮҝгғјгғҹгғҠгғ«CTFгҖӮж—Ҙжң¬иӘһ:  SQ_LANG=ja ./sq help
#
set -euo pipefail

# --- locate ourselves so sq works from anywhere -----------------------------
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORLD="$ROOT/world"
STATE="$ROOT/.sq_state"
KEYS="$ROOT/.sq_keys"
TOKENF="$ROOT/.sq_token"
LEVELS=10

# --- language ----------------------------------------------------------------
# SQ_LANG=ja forces Japanese, SQ_LANG=en forces English.
# Unset: auto-detect from the system locale ($LANG).
SQ_LANG="${SQ_LANG:-}"
if [ -z "$SQ_LANG" ]; then
  case "${LANG:-}" in ja*) SQ_LANG=ja ;; *) SQ_LANG=en ;; esac
fi
is_ja() { [ "$SQ_LANG" = "ja" ]; }

# --- colors -----------------------------------------------------------------
if [ -t 1 ]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; B=$'\e[34m'; M=$'\e[35m'; C=$'\e[36m'
  BOLD=$'\e[1m'; DIM=$'\e[2m'; N=$'\e[0m'
else
  R=""; G=""; Y=""; B=""; M=""; C=""; BOLD=""; DIM=""; N=""
fi

say()  { printf '%s\n' "$*"; }
line() { say "${DIM}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${N}"; }

sha() { printf '%s' "$1" | sha256sum | cut -d' ' -f1; }

