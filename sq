do_help() {
  banner
  say "${BOLD}COMMANDS${N}"
  say "  ${C}./sq start${N}          Begin (generates the ship) and show deck 0"
  say "  ${C}./sq brief${N}          Show the current deck's mission"
  say "  ${C}./sq hint${N}           Get a hint for the current deck"
  say "  ${C}./sq submit SQ{..}${N}  Turn in a flag to advance"
  say "  ${C}./sq status${N}         Show your progress"
  say "  ${C}./sq map${N}            Show all decks and what each teaches"
  say "  ${C}./sq reset${N}          Rebuild a fresh random ship (new flags)"
  say "  ${C}./sq help${N}           This screen"
  say ""
  say "${BOLD}HOW TO PLAY${N}"
  say "  1. Read the mission:      ${C}./sq brief${N}"
  say "  2. Explore the deck:      ${C}cd world/level00${N}  then use ls/cat/cd/..."
  say "  3. Find the ${Y}SQ{...}${N} flag hidden there."
  say "  4. Submit it:             ${C}./sq submit SQ{...}${N}"
  say "  5. Repeat through all 10 decks to win."
}

# --- dispatch ---------------------------------------------------------------
cmd="${1:-help}"
case "$cmd" in
  start)  do_reset ;;
  reset)  do_reset ;;
  brief|mission) do_brief ;;
  hint)   do_hint ;;
  status) do_status ;;
  map)    do_map ;;
  submit) shift; do_submit "${1:-}" ;;
  help|-h|--help) do_help ;;
  *) say "${R}Unknown command:${N} $cmd"; say "Run ${C}./sq help${N}"; exit 1 ;;
esac
