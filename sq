brief_text() { if is_ja; then brief_text_ja "$1"; else brief_text_en "$1"; fi; }

hint_text_en() {
  case "$1" in
  0) say "The file is literally named ${C}welcome.txt${N}. ${DIM}cat world/level00/welcome.txt${N}";;
  1) say "Hidden files start with a dot. ${DIM}ls -a${N} shows them; the flag is in ${C}.crew_manifest${N}.";;
  2) say "At every folder run ${DIM}ls${N}; follow the only sub-folder that exists until you hit ${C}flag.txt${N}.";;
  3) say "${DIM}grep -rl 'SQ{' .${N} prints WHICH file matches; then ${DIM}cat${N} that file.";;
  4) say "${DIM}tail -n 1 logbook.txt${N} shows only the final line.";;
  5) say "${DIM}find . -name 'treasure*' -type f${N} then ${DIM}cat${N} the exact path.";;
  6) say "Match many files with a wildcard: ${DIM}rm decoy_*.txt${N}. Then only treasure.txt is left.";;
  7) say "${DIM}chmod u+r flag.txt${N} adds the 'user read' permission, then ${DIM}cat flag.txt${N}.";;
  8) say "Order matters: ${DIM}cat left.piece right.piece${N} (left first).";;
  9) say "Chain it: ${DIM}f=\$(find . -name '*.enc'); chmod u+r \"\$f\"; base64 -d \"\$f\"${N}";;
  esac
}

hint_text_ja() {
  case "$1" in
  0) say "гғ•гӮЎгӮӨгғ«еҗҚгҒҜгҒқгҒ®гҒҫгҒҫ ${C}welcome.txt${N}гҖӮ ${DIM}cat world/level00/welcome.txt${N}";;
  1) say "йҡ гҒ—гғ•гӮЎгӮӨгғ«гҒҜгғүгғғгғҲгҒ§е§ӢгҒҫгӮӢгҖӮ${DIM}ls -a${N} гҒ§иЎЁзӨәгҒ•гӮҢгӮӢгҖӮгғ•гғ©гӮ°гҒҜ ${C}.crew_manifest${N} гҒ®дёӯгҖӮ";;
  2) say "еҗ„гғ•гӮ©гғ«гғҖгҒ§ ${DIM}ls${N} гӮ’е®ҹиЎҢгҒ—гҖҒе”ҜдёҖеӯҳеңЁгҒҷгӮӢгӮөгғ–гғ•гӮ©гғ«гғҖгӮ’ ${C}flag.txt${N} гҒ«еҪ“гҒҹгӮӢгҒҫгҒ§гҒҹгҒ©гӮӢгҖӮ";;
  3) say "${DIM}grep -rl 'SQ{' .${N} гҒҜгҖҢгҒ©гҒ®гғ•гӮЎгӮӨгғ«гҒҢгҖҚдёҖиҮҙгҒ—гҒҹгҒӢгӮ’иЎЁзӨәгҒҷгӮӢгҖӮгҒӮгҒЁгҒҜгҒқгӮҢгӮ’ ${DIM}cat${N}гҖӮ";;
  4) say "${DIM}tail -n 1 logbook.txt${N} гҒ§жңҖзөӮиЎҢгҒ гҒ‘гӮ’иЎЁзӨәгҒ§гҒҚгӮӢгҖӮ";;
  5) say "${DIM}find . -name 'treasure*' -type f${N} гҒ®гҒӮгҒЁгҖҒиЎЁзӨәгҒ•гӮҢгҒҹгғ‘гӮ№гӮ’ ${DIM}cat${N}гҖӮ";;
  6) say "гғҜгӮӨгғ«гғүгӮ«гғјгғүгҒ§гҒҫгҒЁгӮҒгҒҰеүҠйҷӨ: ${DIM}rm decoy_*.txt${N}гҖӮж®ӢгӮӢгҒ®гҒҜ treasure.txt гҒ гҒ‘гҖӮ";;
  7) say "${DIM}chmod u+r flag.txt${N} гҒ§гҖҢгғҰгғјгӮ¶гғјиӘӯгҒҝеҸ–гӮҠгҖҚжЁ©йҷҗгӮ’иҝҪеҠ гҒ—гҒҰгҒӢгӮү ${DIM}cat flag.txt${N}гҖӮ";;
  8) say "й Ҷз•ӘгҒҢеӨ§дәӢ: ${DIM}cat left.piece right.piece${N}пјҲleft гҒҢе…ҲпјүгҖӮ";;
  9) say "гҒӨгҒӘгҒ’гҒҰдёҖж’ғ: ${DIM}f=\$(find . -name '*.enc'); chmod u+r \"\$f\"; base64 -d \"\$f\"${N}";;
  esac
}

hint_text() { if is_ja; then hint_text_ja "$1"; else hint_text_en "$1"; fi; }

