  printf '%s\n' "${whole:$half}"    > "$WORLD/level08/right.piece"
  if is_ja; then
    echo "1гҒӨгҒ®гғ•гғ©гӮ°гҒҢ2гҒӨгҒ«еүІгӮҢгҒҰгҒ„гӮӢгҖӮleft гӮ’е…ҲгҒ«гҒ—гҒҰ cat гҒ§гҒӨгҒӘгҒ’гӮҲгҖӮ" \
      > "$WORLD/level08/README.txt"
  else
    echo "Two halves of one flag. cat them together, left first." \
      > "$WORLD/level08/README.txt"
  fi

  # L9 --------------------------------------------------------------------
  local z="$WORLD/level09"
  mkdir -p "$z/core/shielding/conduit_7/junction"
  if is_ja; then
    echo "еӣ®гҒ " > "$z/core/notes.txt"
    echo "еӣ®гҒ " > "$z/core/shielding/manual.txt"
  else
    echo "decoy" > "$z/core/notes.txt"
    echo "decoy" > "$z/core/shielding/manual.txt"
  fi
  printf '%s' "${flags[9]}" | base64 > "$z/core/shielding/conduit_7/junction/core_key.enc"
  chmod 000 "$z/core/shielding/conduit_7/junction/core_key.enc"

  # ensure everything we made is at least traversable/readable (except the
  # two we deliberately locked, which we re-lock last)
  chmod -R u+rwX "$WORLD"
  chmod 000 "$WORLD/level07/flag.txt"
  chmod 000 "$z/core/shielding/conduit_7/junction/core_key.enc"
}

require_world() {
  if [ ! -d "$WORLD" ] || [ ! -f "$KEYS" ]; then
    if is_ja; then
      say "${Y}гӮІгғјгғ гғҜгғјгғ«гғүгҒҢгҒҫгҒ гҒӮгӮҠгҒҫгҒӣгӮ“гҖӮз”ҹжҲҗгҒ—гҒҫгҒҷ...${N}"
    else
      say "${Y}No game world yet. Generating one...${N}"
    fi
    do_reset
  fi
}

cur_level() { cat "$STATE" 2>/dev/null || echo 0; }

progress_bar() {
  local done="$1" total="$2" i out=""
  for ((i=0;i<total;i++)); do
    if [ "$i" -lt "$done" ]; then out+="${G}в–Ҳ${N}"; else out+="${DIM}в–‘${N}"; fi
  done
  printf '%s' "$out"
}

# --- commands ---------------------------------------------------------------
do_reset() {
  local token
  token="$(head -c16 /dev/urandom | od -An -tx1 | tr -d ' \n')"
  echo "$token" > "$TOKENF"
  gen_world "$token"
  echo 0 > "$STATE"
  if is_ja; then
    say "${G}ж–°гҒ—гҒ„иҲ№гӮ’з”ҹжҲҗгҒ—гҒҫгҒ—гҒҹ:${N} ${C}$WORLD${N}"
  else
    say "${G}A fresh ship has been generated in:${N} ${C}$WORLD${N}"
  fi
  say ""
  do_brief
}

do_brief() {
  require_world
  local lvl; lvl="$(cur_level)"
  if [ "$lvl" -ge "$LEVELS" ]; then do_status; return; fi
  line
  if is_ja; then
    say "${BOLD}${M}гғҮгғғгӮӯ $lvl вҖ” ${LEVEL_NAME[$lvl]}${N}   ${DIM}(еӯҰгҒ¶гҒ“гҒЁ: ${LEVEL_TEACH[$lvl]})${N}"
  else
    say "${BOLD}${M}DECK $lvl вҖ” ${LEVEL_NAME[$lvl]}${N}   ${DIM}(teaches: ${LEVEL_TEACH[$lvl]})${N}"
  fi
  line
  brief_text "$lvl"
  line
  if is_ja; then
    say "жҺўзҙў:      ${C}cd $WORLD/level0$lvl${N}"
    say "еӣ°гҒЈгҒҹгӮү?  ${C}./sq hint${N}      жҸҗеҮә:  ${C}./sq submit SQ{...}${N}"
  else
    say "Explore in:  ${C}cd $WORLD/level0$lvl${N}"
    say "Stuck?       ${C}./sq hint${N}      Submit:  ${C}./sq submit SQ{...}${N}"
  fi
}

do_hint() {
  require_world
  local lvl; lvl="$(cur_level)"
  if [ "$lvl" -ge "$LEVELS" ]; then
    if is_ja; then say "${G}гӮІгғјгғ гҒҜгҒҷгҒ§гҒ«гӮҜгғӘгӮўжёҲгҒҝ!${N}"; else say "${G}Game already complete!${N}"; fi
    return
  fi
  if is_ja; then
    say "${Y}гғ’гғігғҲ (гғҮгғғгӮӯ $lvl):${N}"
  else
    say "${Y}HINT (deck $lvl):${N}"
  fi
  hint_text "$lvl"
}

do_status() {
  require_world
  local lvl; lvl="$(cur_level)"
  line
  if is_ja; then
    say "${BOLD}SHELL QUEST вҖ” гӮ№гғҶгғјгӮҝгӮ№${N}"
    say "йҖІжҚ—: $(progress_bar "$lvl" "$LEVELS")  ${BOLD}$lvl/$LEVELS${N} гғҮгғғгӮӯдҝ®зҗҶжёҲгҒҝ"
    line
    if [ "$lvl" -ge "$LEVELS" ]; then
      say "${G}${BOLD}вҳ… иҲ№гҒҜе®Ңе…Ёеҫ©ж—§гҖӮShell Quest гӮҜгғӘгӮўпјҒ вҳ…${N}"
      say "ж–°гҒ—гҒ„гғ©гғігғҖгғ гҒӘиҲ№гҒ§еҶҚжҢ‘жҲҰ:  ${C}./sq reset${N}"
    else
      say "зҸҫеңЁгҒ®гғҮгғғгӮӯ: ${M}$lvl вҖ” ${LEVEL_NAME[$lvl]}${N}"
      say "гғҹгғғгӮ·гғ§гғігӮ’иҰӢгӮӢгҒ«гҒҜ ${C}./sq brief${N}гҖӮ"
    fi
  else
    say "${BOLD}SHELL QUEST вҖ” status${N}"
    say "Progress: $(progress_bar "$lvl" "$LEVELS")  ${BOLD}$lvl/$LEVELS${N} decks repaired"
    line
    if [ "$lvl" -ge "$LEVELS" ]; then
      say "${G}${BOLD}вҳ… SHIP FULLY RESTORED. You beat Shell Quest! вҳ…${N}"
      say "Replay with a new random ship:  ${C}./sq reset${N}"
    else
      say "Current deck: ${M}$lvl вҖ” ${LEVEL_NAME[$lvl]}${N}"
      say "Run ${C}./sq brief${N} for the mission."
    fi
  fi
}

do_map() {
  require_world
  local lvl i mark; lvl="$(cur_level)"
  line
  if is_ja; then say "${BOLD}иҲ№еҶ…гғһгғғгғ—${N}"; else say "${BOLD}SHIP MAP${N}"; fi
  line
  for i in $(seq 0 $((LEVELS-1))); do
    if [ "$i" -lt "$lvl" ]; then mark="${G}[вң“]${N}"
    elif [ "$i" -eq "$lvl" ]; then mark="${Y}[вҶ’]${N}"
    else mark="${DIM}[ ]${N}"; fi
    if is_ja; then
      # no fixed-width padding: CJK characters break printf column alignment
      printf '%s гғҮгғғгӮӯ %s  %s  %s%s%s\n' "$mark" "$i" "${LEVEL_NAME[$i]}" "$DIM" "${LEVEL_TEACH[$i]}" "$N"
    else
      printf '%s Deck %s  %-24s %s%s%s\n' "$mark" "$i" "${LEVEL_NAME[$i]}" "$DIM" "${LEVEL_TEACH[$i]}" "$N"
    fi
  done
}

do_submit() {
  require_world
  local guess="${1:-}"
  if [ -z "$guess" ]; then
    if is_ja; then say "${R}дҪҝгҒ„ж–№:${N} ./sq submit SQ{...}"; else say "${R}Usage:${N} ./sq submit SQ{...}"; fi
    return 1
  fi
  local lvl; lvl="$(cur_level)"
  if [ "$lvl" -ge "$LEVELS" ]; then
    if is_ja; then
      say "${G}гҒҷгҒ§гҒ«гӮҜгғӘгӮўжёҲгҒҝгҒ§гҒҷгҖӮеҶҚжҢ‘жҲҰгҒҜ ./sq resetгҖӮ${N}"
    else
      say "${G}You already finished. ./sq reset to replay.${N}"
    fi
    return
  fi

  local want; want="$(grep "^$lvl " "$KEYS" | cut -d' ' -f2)"
  local got; got="$(sha "$guess")"

  if [ "$got" = "$want" ]; then
    say ""
    if is_ja; then
      say "${G}${BOLD}вң” жӯЈи§ЈпјҒ${N} гғҮгғғгӮӯ $lvl гӮ’дҝ®зҗҶгҒ—гҒҹгҖӮ${G}йӣ»еҠӣеӣһеҫ©гҖӮ${N}"
    else
      say "${G}${BOLD}вң” CORRECT!${N} Deck $lvl repaired. ${G}Power restored.${N}"
    fi
    local next=$((lvl+1))
    echo "$next" > "$STATE"
    if [ "$next" -ge "$LEVELS" ]; then
      say ""
      say "${G}${BOLD}"
      if is_ja; then
        say "   вҳ…вҳ…вҳ…  е…ЁгғҮгғғгӮӯеҫ©ж—§ вҖ” SHELL QUEST гӮҜгғӘгӮўпјҒ  вҳ…вҳ…вҳ…"
        say "${N}"
        say "еӯҰгӮ“гҒ гӮігғһгғігғү: ls, cat, cd, pwd, grep, tail, find, rm, chmod, base64гҖӮ"
        say "ж–°гҒ—гҒ„иҲ№гҒ§гӮӮгҒҶдёҖеәҰ:  ${C}./sq reset${N}"
      else
        say "   вҳ…вҳ…вҳ…  ALL DECKS ONLINE вҖ” YOU WIN SHELL QUEST!  вҳ…вҳ…вҳ…"
        say "${N}"
        say "You learned: ls, cat, cd, pwd, grep, tail, find, rm, chmod, base64."
        say "Play again with a new ship:  ${C}./sq reset${N}"
      fi
    else
      say ""
      do_brief
    fi
  else
    if is_ja; then
      say "${R}вңҳ дёҚжӯЈи§ЈгҖӮ${N} гҒқгҒ®гғ•гғ©гӮ°гҒҜгғҮгғғгӮӯ $lvl гҒ®гӮӮгҒ®гҒ§гҒҜгҒӘгҒ„гҖӮжҺҳгӮҠз¶ҡгҒ‘гӮҲгҖӮ"
      say "   ${DIM}(гғ•гғ©гӮ°гҒҜ SQ{...} гҒ®еҪўејҸ вҖ” жіўгҒӢгҒЈгҒ“гӮӮеҗ«гӮҒгҒҰдёёгҒ”гҒЁгӮігғ”гғј)${N}"
      say "   гғ’гғігғҲгҒҢж¬ІгҒ—гҒ„?  ${C}./sq hint${N}"
    else
      say "${R}вңҳ Nope.${N} That flag doesn't match deck $lvl. Keep digging."
      say "   ${DIM}(flags look like SQ{...} вҖ” copy the whole thing, braces included)${N}"
      say "   Need a nudge?  ${C}./sq hint${N}"
    fi
    return 1
  fi
}

